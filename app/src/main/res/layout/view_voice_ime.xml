<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="320dp"
    android:background="@android:color/transparent"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/ime_bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/ime_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_voice_ime_status"
            android:elevation="8dp"
            android:maxWidth="240dp"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/ime_panel_status_default"
            android:textColor="#3F3A36"
            android:textSize="13sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/ime_bubble_button"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_voice_ime_bubble_idle"
            android:clickable="true"
            android:contentDescription="语音输入球"
            android:elevation="10dp"
            android:focusable="true"
            android:gravity="center"
            android:hapticFeedbackEnabled="true"
            android:longClickable="true"
            android:text=""
            android:textColor="#FFFFFF" />
    </LinearLayout>
</FrameLayout>
